<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Chat_Room</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <Target Name="CopyChannelWindow" AfterTargets="Build">
    <ItemGroup>
      <ChannelWindowFiles Include="..\ChannelWindow\bin\$(Configuration)\net8.0\ChannelWindow.*" />
    </ItemGroup>
    <Copy SourceFiles="@(ChannelWindowFiles)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>

</Project>
